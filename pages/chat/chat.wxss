/* AI问答页面样式 */

.chat-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.message-list {
  flex: 1;
  padding: 20rpx;
}

.message {
  margin-bottom: 20rpx;
  display: flex;
}

.message.user {
  justify-content: flex-end;
}

.message.assistant {
  justify-content: flex-start;
}

.message-content {
  max-width: 70%;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.message.user .message-content {
  background: #07c160;
  color: #fff;
}

.message.assistant .message-content {
  background: #fff;
  color: #333;
  border: 1rpx solid #e5e5e5;
}

.loading {
  color: #999;
}

.input-area {
  padding: 16rpx;
  background: #fff;
  border-top: 1rpx solid #e5e5e5;
  display: flex;
  gap: 16rpx;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  padding: 0 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  background: #07c160;
  color: #fff;
  border-radius: 8rpx;
}

.send-btn[disabled] {
  background: #ccc;
}

.toolbar {
  padding: 8rpx 16rpx;
  background: #fff;
  border-top: 1rpx solid #e5e5e5;
}

.clear-btn {
  color: #576b95;
}