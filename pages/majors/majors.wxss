/* 专业列表样式 */

.container {
  padding: 32rpx;
}

.search-bar {
  margin-bottom: 24rpx;
}

.search-bar input {
  width: 100%;
  height: 72rpx;
  padding: 0 16rpx;
  background: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.loading, .empty {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

.major-list {
  background: #fff;
  border-radius: 16rpx;
}

.major-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.major-item:last-child {
  border-bottom: none;
}

.major-name {
  font-size: 32rpx;
  color: #333;
}

.major-category {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}