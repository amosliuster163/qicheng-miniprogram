/* 首页样式 */

.container {
  padding: 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo {
  font-size: 72rpx;
  font-weight: bold;
  color: #07c160;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  margin-top: 16rpx;
}

.features {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.feature-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.feature-icon {
  font-size: 48rpx;
}

.feature-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.feature-desc {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.hot-questions {
  margin-top: 60rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.question-item {
  background: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  color: #333;
  font-size: 28rpx;
}