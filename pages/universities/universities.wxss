/* 学校列表样式 */

.container {
  padding: 32rpx;
  background: #f5f5f5;
}

.type-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  background: #fff;
  padding: 16rpx;
  border-radius: 12rpx;
}

.type-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 26rpx;
}

.type-tab.active {
  background: #07c160;
  color: #fff;
}

.loading {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

.uni-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.uni-card {
  background: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
}

.uni-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.uni-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.uni-tags {
  display: flex;
  gap: 8rpx;
}

.tag {
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.tag.level {
  background: #07c160;
  color: #fff;
}

.tag.location {
  background: #576b95;
  color: #fff;
}

.uni-desc {
  color: #666;
  font-size: 24rpx;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.uni-majors {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.label {
  color: #666;
}

.value {
  color: #333;
}

.uni-stats {
  display: flex;
  gap: 24rpx;
}

.stat {
  display: flex;
  flex-direction: column;
}

.stat-label {
  font-size: 22rpx;
  color: #666;
}

.stat-value {
  font-size: 26rpx;
  color: #333;
}

.stat-value.highlight {
  color: #07c160;
  font-weight: bold;
}

.empty {
  text-align: center;
  padding: 100rpx;
  color: #999;
}