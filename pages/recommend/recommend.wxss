/* 择校推荐样式 */

.container {
  padding: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.input-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

input {
  width: 100%;
  height: 72rpx;
  padding: 0 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  margin-top: 16rpx;
}

.submit-btn[disabled] {
  background: #ccc;
}

.result-section {
  margin-top: 32rpx;
}

.school-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.school-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.school-info {
  margin-top: 16rpx;
  display: flex;
  gap: 16rpx;
}

.tag {
  background: #07c160;
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.location {
  color: #666;
  font-size: 24rpx;
}

.school-desc {
  margin-top: 16rpx;
  color: #666;
  font-size: 26rpx;
}

.tips {
  background: #fff7e6;
  padding: 24rpx;
  border-radius: 12rpx;
  color: #fa8c16;
  font-size: 26rpx;
  margin-top: 24rpx;
}

.reset-btn {
  width: 100%;
  height: 72rpx;
  background: #f5f5f5;
  color: #333;
  margin-top: 24rpx;
}