/**
 * 全局样式
 */

/* 重置 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  color: #333;
  background: #f5f5f5;
}

/* WeUI变量 */
.container {
  padding: 32rpx;
}

.btn-primary {
  background: #07c160;
  color: #fff;
}

.btn-secondary {
  background: #f5f5f5;
  color: #333;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}